generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/request-inquiry-client"
}

datasource db {
  provider = "postgresql"
  url      = env("REQUEST_INQUIRY_DATABASE_URL")
}

model ExhibitionVisitor {
  id          String    @id @default(uuid())
  name        String    @map("name")
  workPhone   String    @map("work_phone")
  isConverted Boolean   @default(false) @map("is_converted")
  convertedAt DateTime? @map("converted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  programs VisitorProgram[]
  metadata VisitorMetadata?

  @@map("exhibition_visitors")
}

model Program {
  id          Int      @id @default(autoincrement())
  programName String   @unique @map("program_name")
  category    String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  visitors VisitorProgram[]

  @@map("programs")
}

model VisitorProgram {
  id        String   @id @default(uuid())
  visitorId String   @map("visitor_id")
  programId Int      @map("program_id")
  createdAt DateTime @default(now()) @map("created_at")

  visitor ExhibitionVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  program Program            @relation(fields: [programId], references: [id])

  @@unique([visitorId, programId])
  @@map("visitor_programs")
}

model VisitorMetadata {
  id            String    @id @default(uuid())
  visitorId     String    @unique @map("visitor_id")
  ipAddress     String?   @map("ip_address")
  country       String?
  city          String?
  region        String?
  timezone      String?
  userAgent     String?   @map("user_agent")
  browser       String?
  device        String?
  submissionDate DateTime? @map("submission_date") @db.Date
  submissionTime DateTime? @map("submission_time") @db.Time
  createdAt     DateTime  @default(now()) @map("created_at")

  visitor ExhibitionVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@map("visitor_metadata")
}
