# Local development environment variables (example)
#
# Copy this file to `.env` and update the values.
# NOTE: `.env` is intentionally not committed.

# ========================================
# Database (PostgreSQL)
# ========================================
# Prisma expects a single connection string in `DATABASE_URL`.
#
# Neon (direct):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.us-east-1.aws.neon.tech/DB?sslmode=require"
#
# Supabase (with connection pooling):
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
#
# Vercel Postgres:
# DATABASE_URL="<paste your Vercel Postgres Prisma URL here>"
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# DIRECT_URL is required by Prisma schema for migrations and introspection
# If not using connection pooling, set it to the same value as DATABASE_URL
# If using Supabase/Neon pooling, use the direct (non-pooled) connection URL
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Optional (only needed for the SQLite -> Postgres migration script)
SQLITE_DATABASE_URL="file:./prisma/dev.db"

# ========================================
# Auth (required)
# ========================================
# Must be at least 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-at-least-32-random-characters"

# ========================================
# Optional: AI Chat (Gemini)
# ========================================
# GEMINI_API_KEY="your-gemini-api-key"

# ========================================
# Optional: S3 storage
# ========================================
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_S3_BUCKET_NAME="..."

# ========================================
# Web Push Notifications (VAPID Keys)
# ========================================
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
# VAPID_PRIVATE_KEY="your-vapid-private-key"
# VAPID_SUBJECT="mailto:admin@example.com"
