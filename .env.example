# Local development environment variables (example)
#
# Copy this file to `.env` and update the values.
# NOTE: `.env` is intentionally not committed.
#
# ========================================
# Database (local SQLite by default)
# ========================================
# For local development we default to SQLite. In production/Vercel,
# use Supabase/Vercel Postgres via `vercel.env` / Vercel dashboard.
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# Optional (only needed for the SQLite -> Postgres migration script)
SQLITE_DATABASE_URL="file:./prisma/dev.db"

# ========================================
# Auth (required)
# ========================================
# Must be at least 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-at-least-32-random-characters"

# ========================================
# Vercel Cron: 48h follow-up compliance alerts (production)
# ========================================
# Set in Vercel → Project → Settings → Environment Variables.
# Vercel sends Authorization: Bearer <CRON_SECRET> when invoking /api/cron/follow-up-compliance.
# Local test: curl -H "Authorization: Bearer YOUR_SECRET" http://localhost:3000/api/cron/follow-up-compliance
# CRON_SECRET="min-16-chars-recommended-use-openssl-rand-base64-24"

# ========================================
# Optional: AI Chat (Gemini)
# ========================================
GEMINI_API_KEY="your-gemini-api-key"

# ========================================
# Optional: Email
# ========================================
SMTP_PROVIDER="mailjet"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_FROM_NAME="CRM System"

# Mailjet (optional, used if SMTP_USER/SMTP_PASS not set)
MAILJET_API_KEY=""
MAILJET_API_SECRET=""

# SendGrid (optional)
SENDGRID_API_KEY=""

# SendPulse (optional)
SENDPULSE_USER_ID=""
SENDPULSE_SECRET=""

# Gmail OAuth (optional; used by src/lib/gmail.ts)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""

# ========================================
# Optional: S3 storage
# ========================================
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
